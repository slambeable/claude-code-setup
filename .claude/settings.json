{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run test *)",
      "Bash(npm run lint *)",
      "Bash(npm run format *)",
      "Bash(npm run type-check)",
      "Bash(npx vitest *)",
      "Bash(npx vue-tsc *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git branch *)",
      "Read",
      "Write",
      "Edit",
      "MultiEdit"
    ],

    "ask": [
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],

    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git push * --force)",
      "Bash(git push * -f)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(npm publish *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Write(./.env)",
      "Write(./.env.*)"
    ]
  }
}
